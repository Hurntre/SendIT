{
  "name": "send-it",
  "version": "1.0.0",
  "description": "Send-IT - a courier service that helps users deliver parcels to different destinations",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production && npm run build && node dist/index.js",
    "start:dev": "nodemon server/index.js --exec babel-node",
    "build": "babel server -d dist",
    "test": "cross-env NODE_ENV=test && nyc  --reporter=html --reporter=text mocha tests --recursive --timeout 20000 --require @babel/register --exit",
    "eslint:check": " node node_modules/eslint/bin/eslint.js \"./**/*.js\"",
    "prettier:check": "prettier --check \"./**/*.js\"",
    "prettier:fix": "prettier --write \"./**/*.js\"",
    "check:lint-prettier": "npm run eslint:check && npm run prettier:check",
    "pretest": "npm run check:lint-prettier",
    "coverage": "nyc report --reporter=text-lcov | coveralls",
    "check:coverage": "nyc check-coverage --lines 80"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hurntre/SendIT.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Hurntre/SendIT/issues"
  },
  "homepage": "https://github.com/Hurntre/SendIT#readme",
  "devDependencies": {
    "chai": "^4.2.0",
    "chai-http": "^4.2.1",
    "coveralls": "^3.0.3",
    "eslint": "^5.15.3",
    "eslint-config-airbnb-base": "^13.1.0",
    "eslint-config-prettier": "^4.1.0",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-prettier": "^3.0.1",
    "mocha": "^6.1.4",
    "nodemon": "^1.18.10",
    "nyc": "^14.0.0",
    "prettier": "^1.16.4"
  },
  "dependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.4.0",
    "@babel/node": "^7.2.2",
    "@babel/plugin-transform-runtime": "^7.4.0",
    "@babel/polyfill": "^7.4.0",
    "@babel/preset-env": "^7.4.2",
    "@babel/register": "^7.4.0",
    "@hapi/joi": "^16.1.4",
    "babel-eslint": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cross-env": "^6.0.3",
    "dotenv": "^7.0.0",
    "express": "^4.16.4",
    "husky": "^1.3.1",
    "jsonwebtoken": "^8.5.1",
    "lint-staged": "^8.1.5",
    "mockgoose": "^8.0.3",
    "moment": "^2.24.0",
    "mongoose": "^5.7.5",
    "swagger-jsdoc": "^3.2.9",
    "swagger-ui-express": "^4.1.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "*.{js,json,css,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "nyc": {
    "exclude": [
      "server/db/*.js",
      "tests"
    ]
  }
}
